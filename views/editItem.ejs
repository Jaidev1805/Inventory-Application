<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Item</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <a class="brand" href="/">Inventory</a>
            <nav class="topnav">
                <a class="nav-link" href="/">Home</a>
                <a class="nav-link" href="/categories">Categories</a>
                <a class="nav-link active" href="/items">Items</a>
            </nav>
            <div class="topbar-actions">
                <a class="button" href="/items/<%= item.id %>">Back</a>
            </div>
        </header>

        <main class="page">
            <section class="page-header">
                <div>
                    <p class="eyebrow">Edit</p>
                    <h1 class="page-title">Edit item</h1>
                    <p class="page-intro">Adjust the product details while preserving the existing inventory flow.</p>
                </div>
            </section>

            <section class="form-card">
                <% if (errors && errors.length > 0) { %>
                    <ul class="form-errors">
                        <% errors.forEach(error => { %>
                            <li class="error-item"><%= error.msg %></li>
                        <% }) %>
                    </ul>
                <% } %>

                <form class="form-grid" action="/items/<%= item.id %>" method="POST">
                    <div class="field">
                        <label for="name">Name</label>
                        <input type="text" id="name" name="name" value="<%= values && values.name ? values.name : '' %>" required>
                    </div>

                    <div class="field">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" required><%= values && values.description ? values.description : '' %></textarea>
                    </div>

                    <div class="field">
                        <label for="price">Price</label>
                        <input type="number" id="price" name="price" step="0.01" min="0.01" value="<%= values && values.price ? values.price : '' %>" required>
                    </div>

                    <div class="field">
                        <label for="stock">Stock</label>
                        <input type="number" id="stock" name="stock" min="0" value="<%= values && (values.stock !== undefined && values.stock !== null) ? values.stock : '' %>" required>
                    </div>

                    <div class="field">
                        <label for="category_id">Category</label>
                        <select id="category_id" name="category_id" required>
                            <option value="">Select a category</option>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.id %>" <%= values && values.category_id == category.id ? 'selected' : '' %>><%= category.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-actions">
                        <button class="button button-primary" type="submit">Save changes</button>
                        <a class="button" href="/items/<%= item.id %>">Cancel</a>
                    </div>
                </form>
            </section>
        </main>
    </div>
</body>
</html>
